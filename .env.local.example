# ============================================================
# .env.local.example — copy to .env.local and fill in values.
# .env.local is gitignored and never committed.
#
# Get your keys from:
#   Supabase → Settings → API Keys → "API Keys" tab (not Legacy)
#   Copy the "Publishable key" (starts with sb_publishable_...)
#
# The publishable key is safe to expose in client-side code.
# Never use the secret key (sb_secret_...) in the browser.
# ============================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
